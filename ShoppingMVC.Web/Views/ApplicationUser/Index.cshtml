@model IPagedList<ApplicationUserListVM>
@using ShoppingMVC.Web.ViewModels.ApplicationUser
@using X.PagedList
@{
    ViewData["Title"] = "Customers List";
}
<div class="container" >
    @Html.AntiForgeryToken() 
    <div class="row mb-3">
        <div class="col-6" style="color:blue">

             <h3> Customer's List</h3>
        </div>
    </div>
    <form method="get" class="form-inline" asp-action="Index" style="padding-bottom:5px">
        <div class="d-flex flex-row align-items-center">
            <div class="col-auto mx-1">
                <label for="pageSize" style="color:brown">Show:</label>
            </div>
            <div class="col-auto mx-2">
                <partial name="_selectPageSize" model="@ViewBag.currentPageSize" />
            </div>
            <div class="col-auto mx-2" style="width:200px;">
                <input type="text" name="searchTerm" id="searchTerm" class="form-control"
                       placeholder="Search By..." value="@ViewBag.currentSearchTerm" />

            </div>
            <div class="col-auto d-flex">
                <button type="submit" class="btn btn-primary mx-2">
                    <i class="bi bi-search"></i> Search
                </button>
                <button type="submit" class="btn btn-secondary" id="viewAll" name="viewAll"
                value="true">
                    <i class="bi bi-list"></i> View All
                </button>

            </div>
        </div>

          
    </form>

</div>
