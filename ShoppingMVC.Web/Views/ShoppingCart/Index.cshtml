@using ShoppingMVC.Web.ViewModels.ShopCart
@model ShoppingCartListVm
@{
    decimal price = 0m;
}
<form method="post">
   
  <div class="card shadow border-0">
        <div class="card-header bg-secondary bg-gradient text-light">
            <div class="row">
                <div class=" col-6">
                    <h5 class="pt-2 text-white">
                        Shopping Cart
                    </h5>
                </div>
            </div>
        </div>

    @if (Model.ShoppingCarts.Any()) // verifico tener productos en la lista
    {
            <div class="card-body">
                <div class="row mb-3 pb-3">
                        <div class="col-md-3 offset-md-1">

                        <a class="btn btn-outline-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2" 
                        asp-controller="Shoe" 
                        asp-action="Index">
                        <i class="bi bi-arrow-left-circle"></i>
                        <span>Continue Shopping</span>
                        </a>
                    </div>
                  <div class="col-md-10 offset-md-1">

                    @foreach (var item in Model.ShoppingCarts!)
                    {
                            price = (item.Quantity == 1 ? item.Shoe.Price : item.Shoe.Price * 0.9m);

                            <div class="row border-bottom py-3 align-items-center">

                                <!-- NOMBRE -->
                                <div class="col-lg-4">
                                    <h6 class="mb-0 fw-bold">
                                        @item.Shoe.ShoeName
                                    </h6>
                                </div>

                                <!-- PRECIO x CANTIDAD -->
                                <div class="col-lg-3 text-center">
                                    <span>
                                        @price.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))
                                        × @item.Quantity
                                    </span>
                                </div>

                                <!-- SUBTOTAL -->
                                <div class="col-lg-2 text-center fw-bold">
                                    @((price * item.Quantity).ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US")))
                                </div>

                                <!-- BOTONES -->
                                <div class="col-lg-3 d-flex justify-content-center gap-2">

                                    <a class="btn btn-outline-secondary btn-sm"
                                       asp-action="Add"
                                       asp-route-shoeId="@item.ShoeId">
                                        +
                                    </a>

                                    <a class="btn btn-outline-secondary btn-sm"
                                       asp-action="Minus"
                                       asp-route-shoeId="@item.ShoeId">
                                        -
                                    </a>

                                    <a class="btn btn-danger btn-sm"
                                       asp-action="Remove"
                                       asp-route-shoeId="@item.ShoeId">
                                        🗑
                                    </a>

                                </div>

                            </div>
                    }
                    </div>
                </div>
                <div class="card-footer  bg-light">
                                    <div class="row">
                                        <div class="col-md-4 offset-md-4">
                                            <ul class="list-group mb-4">
                                                <li class="d-flex justify-content-between align-items-center">
                                                    <h5 class="fw-semibold text-uppercase"> TOTAL (USD)</h5>
                                                    <h4 class="fw-bolder">@Model.OrderHeader!.OrderTotal.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-US"))</h4>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                        <div class="row">
                            <div class="col-md-2 offset-md-5">
                            <a asp-action="Summary"
                                asp-route-returnUrl="@Context.Request.Path" 
                                class="btn btn-success btn-lg w-100">
                                Checkout →
                            </a>>
                            </div>
                        </div>
                </div>
            </div>
             
    }
    else
    {
        <div class="alert alert-danger" style="background-color:#000000; color:#ffffff">
            <div class="text-danger text-center fs-3">
                Shopping Cart is empty!!!
            </div>
        </div>
        <a class="btn btn-outline-success" asp-action="Index" asp-controller="Home">
            <i class="bi bi-backspace"></i>
            Back
        </a>
    }
            
 </div>
</form>