@using ShoppingMVC.Web.ViewModels.ShopCart
@model ShoppingCartListVm
@{
    decimal price = 0;
}
<form method="post">

    <input type="hidden" asp-for="@Model.OrderHeader!.ApplicationUserId" />

 <div class="container mt-4">
        <div class="card shadow-lg border-0">
            <!-- HEADER -->
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            
              <h5 class="mb-0">🛒 Checkout</h5>
                <a href="@ViewBag.ReturnUrl ?? Url.Action("Index","Home"))" class="btn btn-outline-danger btn-sm">
                    ← Back to Cart
                </a>
                </div>
            <!-- BODY -->
            <div class="card-body">
                <div class="row">

                    <!-- SHIPPING -->
                    <div class="col-lg-6 mb-4">
                        <h5 class="mb-3 text-primary">Shipping Details</h5>

                        <div class="mb-3">
                            <label asp-for="@Model.OrderHeader.FirstName"></label>
                            <input asp-for="@Model.OrderHeader.FirstName" class="form-control" />
                            <span class="text-danger" asp-validation-for="@Model.OrderHeader.FirstName"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="@Model.OrderHeader.LastName"></label>
                            <input asp-for="@Model.OrderHeader.LastName" class="form-control" />
                            <span class="text-danger" asp-validation-for="@Model.OrderHeader.LastName"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="@Model.OrderHeader.Address"></label>
                            <input asp-for="@Model.OrderHeader.Address" class="form-control" />
                            <span class="text-danger" asp-validation-for="@Model.OrderHeader.Address"></span>
                        </div>
                    </div>


                       </div>
                    </div>
            <!-- SUMMARY -->
            <div class="col-lg-6">
                <h5 class="mb-3 text-success">Order Summary</h5>
                
                <ul class="list-group mb-3">
                   
                    @if (Model.ShoppingCarts != null && Model.ShoppingCarts.Any())
                    {
                    @foreach(var item in Model.ShoppingCarts)
                    {
                        price = (item.Quantity == 1 ? item.Shoe.Price : item.Shoe.Price * 0.9m);

                        <li class="list-group-item d-flex justify-content-between align-items-center">
                               
                            <!-- IZQUIERDA -->
                            <div class="d-flex align-items-center gap-2">
                                    <span class="fw-semibold">@item.Shoe.ShoeName</span>
                                    <span class="badge bg-secondary">Qty: @item.Quantity</span>
                            </div>

                                <!-- DERECHA -->
                             <span class="fw-bold">
                                @((price*item.Quantity).ToString("C",System.Globalization.CultureInfo.CreateSpecificCulture("en-Us")))
                            </span>
                        </li>

                    }
                    }
                    else
                    {
                        <li class="list-group-item text-center text-muted">
                            No items in cart
                        </li>

                    }
                    
                    <li class="list-group-item d-flex justify-content-between fw-bold">
                        <span>Total:</span>
                        <span>
                            @Model.OrderHeader.OrderTotal.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-Us"))
                        </span>
                        </li>
                </ul>
             </div>
         </div>
    </div>
    <!-- FOOTER -->
    <div class="card-footer d-flex justify-content-between align-items-center">
        <small class="text-muted">
            Estimated Arrival:
            @Model.OrderHeader.ShippingDate.ToShortDateString()
            -
            @Model.OrderHeader.ShippingDate.AddDays(3).ToShortDateString()
        </small>
        <div>
            <a asp-controller="Shoe" asp-action="Index" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i>
                Continue Shopping
            </a>

            <button type="submit" class="btn btn-success px-4">
                ✔ Place Order
            </button>
        </div>
    </div>

    </div>
    </div>
</form>