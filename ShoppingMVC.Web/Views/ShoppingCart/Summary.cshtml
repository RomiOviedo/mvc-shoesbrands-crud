@using ShoppingMVC.Web.ViewModels.ShopCart
@model ShoppingCartListVm
@{
    decimal price = 0;
}
<form method="post">

    <input type="hidden" asp-for="@Model.OrderHeader!.ApplicationUserId" />

 <div class="container">
   <div class="card shadow corder-0" style="background-color:black; color:antiquewhite">

        <div class="card-header bg-secondary bg-gradient text-light ml-0 py-4">
            <div class="row px-4">
                <div class="col-6">
                    <h5 class="pt-2 text-white">
                        Shopping Cart
                    </h5>
                </div>
                <div class="col-6 text-end">
                    <a asp-action="Index" asp-route-returnUrl="@ViewBag.ReturnUrl" class="btn btn-outline-danger btn-sm">
                        Back to Cart
                    </a>
                </div>
            </div>

        </div>
        <div class="card-body">
            <div class="container rounded p-2">
                <div class="row">
                    <div class="col-12 col-lg-6 pb-4">
                        <div class="row">
                            <h4 class="d-flex justity-content-between align-items-center mb-3">
                                <span class="text-info">Shipping Details:</span>
                            </h4>
                        </div>
                        <div class="row my-1">
                            <div class="col-3">
                                <label asp-for="@Model.OrderHeader.FirstName" class="form-control">

                                </label>
                            </div>
                            <div class="col-9">
                                <input asp-for="@Model.OrderHeader.FirstName" class="form-control"/>
                                <span class="text-danger" asp-validation-for=@Model.OrderHeader.FirstName></span>
                            </div>
                        </div>
                       <div class="row my-1">
                            <div class="col-3">
                             <label asp-for="@Model.OrderHeader!.LastName"></label>
                            </div>
                            <div class="col-9">
                             <input asp-for="@Model.OrderHeader!.LastName" class="form-control" />
                             <span class="text-danger" asp-validation-for="@Model.OrderHeader!.LastName"></span>
                            </div>
                           </div>
                                  <div class="row my-1">
                            <div class="col-3">
                             <label asp-for="@Model.OrderHeader!.Address"></label>
                            </div>
                            <div class="col-9">
                             <input asp-for="@Model.OrderHeader!.Address" class="form-control" />
                             <span class="text-danger" asp-validation-for="@Model.OrderHeader!.Address"></span>
                            </div>
                       </div>
                    </div>
            </div>
            <div class="col-12 col-lg-5 offset-lg-1">
                <h4 class="d-flex justity-content-between align-items-center mb-3">
                    <span class="text-info">Order Summary</span>
                </h4>
                <ul class="list-group mb-3" style="background-color:lightgreen;color:white">
                   
                    @if (Model.ShoppingCarts != null && Model.ShoppingCarts.Any())
                    {
                    @foreach(var item in Model.ShoppingCarts)
                    {
                        price = (item.Quantity == 1 ? item.Shoe.Price : item.Shoe.Price * 0.9m);

                        <li class="list-group-item d-flex justity-content-between" style="background-color:dimgrey; color:black">
                            <div>
@*                                 <h6 class="my-0">@item.Shoe.Brand</h6>
 *@                                <h6 class="my-0">@item.Shoe.ShoeName</h6>
                                <small class="text-info">Quantity:@item.Quantity</small>

                            </div>
                            <span class="text-info">@((price*item.Quantity).ToString("C",System.Globalization.CultureInfo.CreateSpecificCulture("en-Us")))</span>
                        </li>

                    }
                    }
                    else
                    {
                         <p>No hay productos en el carrito</p>

                    }
                    
                    <li class="list-group-item d-flex justity-content-between bg-light" style="background-color:darkseagreen;color:black">
                           <small class="text-info">Total(USD)</small>                
                           <strong class="text-info">@Model.OrderHeader.OrderTotal.ToString("C", System.Globalization.CultureInfo.CreateSpecificCulture("en-Us"))</strong>
                    </li>
                </ul>
             </div>

         </div>
    </div>
  </div>
            <div class="card-footer">
                <div class="row">
                    <div class="col-12 col-md-8 pt-2">
                        <p style="color:grey; font-size:14px;">
                            Estimate Arrival Date:@($"{Model.OrderHeader.ShippingDate} - {Model.OrderHeader.ShippingDate.AddDays(3)}")

                        </p>
                    </div>


                              <div class="col-6">
                               <button type="submit" class="btn bg-success btn-lg px-4 me-sm-3 fw-bold">  @*  todo type= submit va al [POST], EN ESTE CASO al post de SUMMARY *@
                                  Place Order
                              </button>

                              </div>

                      </div>
                    </div>

            </div>
        </div>
    </div>
   
</form>
<div class="col-12 col-md-4">

    <div class="row">
        <div class="col-6">
            <a href="@ViewBag.ReturnUrl" class="btn btn-outline-primary">
                Continue Shopping
            </a>
        </div>

